{
  "mcpServers": {
    "fetch": {
      "type": "local",
      "command": "uvx",
      "tools": [
        "*"
      ],
      "args": [
        "mcp-server-fetch"
      ]
    },
    "context7": {
      "type": "local",
      "command": "npx",
      "tools": [
        "*"
      ],
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "filesystem": {
      "type": "local",
      "command": "npx",
      "tools": [
        "*"
      ],
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        ".",
        "~/src/",
        "~/.copilot/session-state/"
      ]
    }
  }
}
